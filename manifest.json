{
  "manifest_version": 3,
  "name": "browser-notes",
  "version": "0.1.0",
  "description": "Annotate any webpage and revisit your notes.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "browser-notes"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/content.css"]
    }
  ],
  "commands": {
    "annotate": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Annotate selected text"
    },
    "clear-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Clear all annotations for the current page"
    },
    "retry-highlights": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Retry highlighting all annotations on the current page"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"]
}
